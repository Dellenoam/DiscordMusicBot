# Required: Discord bot token
DISCORD_TOKEN=

# Optional: ratio of voice-channel listeners required to vote-skip a track
# (0.0 - 1.0). Default: 0.5
SKIP_VOTE_RATIO=0.5

# Optional: allow guild administrators to skip instantly (true/false)
# Default: true
ADMIN_INSTANT_SKIP=true

# Optional: allow the requester of a track to skip it instantly (true/false)
# Default: true
REQUESTER_INSTANT_SKIP=true

# Optional: seconds of inactivity (empty queue) before disconnecting
# Default: 180
INACTIVITY_TIMEOUT=180

# Optional: seconds to wait after the voice channel becomes empty before
# disconnecting (allows users to briefly reconnect). 0 = disconnect immediately.
# Default: 30
EMPTY_CHANNEL_GRACE=30

# Optional: log level (DEBUG, INFO, WARNING, ERROR)
# Default: INFO
LOG_LEVEL=INFO

# Optional: bot "playing" activity name (empty = no activity)
# Default: empty
ACTIVITY_NAME=

# Optional: force yt-dlp to bind to IPv4 (avoids YouTube IPv6 throttling on
# some hosts). Default: true
YDL_FORCE_IPV4=true
